# ============================================================================
#  Allowlist-style .gitignore
#  Ignore everything, then re-allow scaffolding + safe file types under
#  configs/ and addons/. users.ini and binaries are force-excluded last.
# ============================================================================

# 1) Ignore everything at the repo root
/*

# 2) Re-allow top-level scaffolding
!/.gitignore
!/README.md
!/setup.sh
!/update.sh
!/sync_to_repo.sh
!/start_cs.sh
!/configs/
!/addons/

# ----------------------------------------------------------------------------
#  Re-allow directory traversal everywhere under configs/ and addons/.
#  (You must un-ignore directories BEFORE you can un-ignore files inside them.)
# ----------------------------------------------------------------------------
!configs/**/
!addons/**/

# ----------------------------------------------------------------------------
#  Re-allow the file types we want to keep, anywhere in the tree
# ----------------------------------------------------------------------------
!**/*.cfg
!**/*.ini
!**/*.txt
!**/*.amxx

# ----------------------------------------------------------------------------
#  Hard exclusions (come last, so they override the re-allows above)
# ----------------------------------------------------------------------------
**/users.ini
**/*.so
**/*.dll
**/*.dat
**/*.mdl
**/*.spr
**/*.wad
**/logs/**
*.log
*.toml
banned.cfg
listip.cfg
